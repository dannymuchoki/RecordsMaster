@model RecordsMaster.Models.RecordItemModel

@{
    ViewData["Title"] = "Record Details";
}

<h2>Record Details</h2>

@if (TempData["Message"] != null)
{
    <div class="alert alert-info">
        @TempData["Message"]
    </div>
}

<table class="table table-bordered">
    <tr>
        <th>CIS</th>
        <td>@Model.CIS</td>
    </tr>
    <tr>
        <th>Barcode</th>
        <td>@Model.BarCode</td>
    </tr>
    <tr>
        <th>Record Type</th>
        <td>@Model.RecordType</td>
    </tr>
    @if (User.IsInRole("Admin"))
    {
        <tr>
            <th>Box Number</th>
            <td>@Model.BoxNumber</td>
        </tr>
        <tr>
            <th>Digitized</th>
            <td>@(Model.Digitized ? "Yes" : "No")</td>
        </tr>
    }
    <tr>
        <th>Closing Date</th>
        <td>@Model.ClosingDate?.ToString("yyyy-MM-dd")</td>
    </tr>
    <tr>
        <th>Destroy Date</th>
        <td>@Model.DestroyDate?.ToString("yyyy-MM-dd")</td>
    </tr>
    <tr>
        <th>Status</th>
        <td>@(Model.CheckedOut ? "Checked Out" : "Available")</td>
    </tr>
    <tr>
        <th>Checkout History</th>
        <td><a href="@Url.Action("CheckoutHistory", "RecordItems", new { id = Model.ID })" class="btn btn btn-info m-1">View History</a></td>
    </tr>
    @if (Model.CheckedOut && Model.CheckedOutTo != null)
    {
        <tr>
            <th>Checked Out To</th>
            <td>@Model.CheckedOutTo.UserName</td>
        </tr>
    }
</table>



@if (Model.Requested)
{
    @if (User.IsInRole("Admin"))
    {
        @if (!Model.ReadyForPickup)
        {
            @if (Model.Digitized)
            {
                <p>This record has been digitized. Get the physical record from <b>Box @Model.BoxNumber</b>. When that's done, click the 'Ready for Pickup' button below </p>
                @using (Html.BeginForm("ReadyForPickup", "RecordCheckOut", new { id = Model.ID }, FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        <input type="submit" value="Ready for Pickup" class="btn btn-success" />                   
                    }
            }
            else{
                @using (Html.BeginForm("ReadyForPickup", "RecordCheckOut", new { id = Model.ID }, FormMethod.Post))
                {
                     @Html.AntiForgeryToken()
                    <input type="submit" value="Ready for Pickup" class="btn btn-success" />                   
                }
            }
        }
        else
            {
                <p>User will have to check out record.</p>
            }
    }
    else{

        @if (!Model.ReadyForPickup){
        <p> You will be notified when the record is ready.</p>
        }
        else{
        <p>The record is ready. Please choose how you'd like to receive it, then click 'Check Out'.</p>

        @using (Html.BeginForm("Checkout", "RecordCheckOut", new { id = Model.ID }, FormMethod.Post)){
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="deliveryOption" id="pickupOption" value="pickup" onchange="handleDeliveryChange()" />
                    <label class="form-check-label" for="pickupOption">I will pick up this record</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="radio" name="deliveryOption" id="sendOption" value="send" onchange="handleDeliveryChange()" />
                    <label class="form-check-label" for="sendOption">Send this record to me</label>
                </div>
            </div>

            <div id="deliveryAddressSection" class="mb-3" style="display:none;">
                <label for="deliveryMessage" class="form-label">Delivery address/instructions</label>
                <input type="text" class="form-control" id="deliveryMessage" name="deliveryMessage" placeholder="Enter your delivery address" />
            </div>

            <input type="submit" id="checkoutButton" value="Check Out" class="btn btn-success" style="display:none;" />
        }
        }

<script>
    function handleDeliveryChange() {
        var sendOption = document.getElementById('sendOption');
        var deliverySection = document.getElementById('deliveryAddressSection');
        var deliverInput = document.getElementById('deliveryMessage');
        var checkoutBtn = document.getElementById('checkoutButton');

        if (sendOption.checked) {
            deliverySection.style.display = 'block';
            deliverInput.required = true;
        } else {
            deliverySection.style.display = 'none';
            deliverInput.required = false;
            deliverInput.value = '';
        }

        checkoutBtn.style.display = 'inline-block';
    }
</script>
    
    
    }


}
else
{
    @if (User.IsInRole("Admin")){

        @if (Model.CheckedOut)
        {
            @using (Html.BeginForm("CheckIn", "RecordCheckIn", new { id = Model.ID }, FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <input type="submit" value="Check In" class="btn btn-danger" />
            }
        }


    }
}

    <br/>
   <a href="@Url.Action("Index", "Home")" class="btn btn-secondary">Back to Search</a>

