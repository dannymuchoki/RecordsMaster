@{
    ViewData["Title"] = "Update Existing Record Items";
}

    <h3>Update Existing Records</h3>
<p>
    Use the form below to update records in the database The file should be formatted with the following columns <b>in this order</b>:
    <table class="table table-bordered mt-2">
        <thead class="table-light">
            <tr>
                <th style="vertical-align:top;">CIS</th>
                <th style="vertical-align:top;">BarCode</th>
                <th style="vertical-align:top;">RecordType</th>
                <th style="vertical-align:top;">Location</th>
                <th style="vertical-align:top;">Box Number</th>
                <th style="vertical-align:top;">Digitized</th>
                <th style="vertical-align:top;">ClosingDate</th>
                <th style="vertical-align:top;">DestroyDate</th>
                <th style="vertical-align:top;">CheckedOut</th>
                <th style="vertical-align:top;">Requested</th>
                <th style="vertical-align:top;">ReadyForPickup</th>
                <th style="vertical-align:top;">CheckedOutTo</th>
            </tr>
        </thead>
    </table>
</p>
 


    <ol>
        <li><a href="/files/update_records_template.csv" download>Download the Update Template</a></li>
        <li>
            <b>CIS</b> and <b>Barcode</b> are required. Without them, you cannot update a record. 
        </li>
        <li>
            You can only update the following columns:
            <ul>
                <li>
                    <b>Location</b>  must be blank <b>or</b> either Records Room or Archives. Leaving it blank means it's in the Records Room by default. 
                </li>
                <li>
                    <b>Box number</b> with a whole integer (that means no decimals, dashes, commas, periods, or letters). Numbers only. 
                </li>
                <li>
                    <b>Digitized</b> must be blank <b>or</b> TRUE or FALSE in all caps.<br/>Check the digital archive to make sure the record's barcode has been digitized before marking <b>Digitized</b> as TRUE.  
                </li>
                <li>
                    <b>CheckedOut</b> and <b>CheckedOutTo</b> must be updated together. 
                     <ol>
                        <li> If <b>CheckedOut</b> is TRUE:</li>
                        <li>Make sure the <b>CheckedOutTo</b> column contains a valid email address.</li>
                    </ol>
                </li>
                <li>
                     Otherwise <b>CheckedOut</b> and <b>CheckedOutTo</b> must both remain blank. 
                </li>
            </ul>

        </li>
    </ol>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Warning"] != null)
    {
        <div class="alert alert-warning">@TempData["Warning"]</div>
    }

    @if (TempData["Errors"] != null)
    {
        <div class="alert alert-danger">
            <ul class="mb-0">
                @foreach (var err in TempData["Errors"]!.ToString()!.Split('|'))
                {
                    <li>@err</li>
                }
            </ul>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <form asp-action="Update" enctype="multipart/form-data" method="post">
        <div asp-validation-summary="All" class="text-danger"></div>

        <div class="form-group">
            <input type="file" class="form-control" id="file" name="file" accept=".csv" />
            
        </div>
        <button type="submit" class="btn btn-primary m-1">Update Existing Records</button>
    </form>
