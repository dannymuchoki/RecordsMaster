@model IEnumerable<RecordsMaster.Models.RecordItemModel>

@if (!User.IsInRole("Admin"))
{
    <h1>You are not authorized to view this page</h1>
    return;
}

<h5>Box Digitization Check</h5>

<form method="get" asp-action="BoxDigitizationCheck" class="border rounded p-3">
    <p>
    Enter a box number. See which records in that box need to be digitized.
</p>
    <div class="input-group">
        <input type="number" id="boxNumber" class="form-control" name="boxNumber" value="@ViewData["BoxNumber"]" placeholder="Enter a box number" />
        <button type="submit" class="btn btn-primary">Check</button>
    </div>
</form>

@if (ViewData["BoxMessage"] != null)
{
    <p><strong>@ViewData["BoxMessage"]</strong></p>
}
else if (Model.Any())
{
    <br/>
    <p>The following records in box @ViewData["BoxNumber"] are not digitized:</p>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>CIS</th>
                <th>Barcode</th>
                <th>Record Type</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var record in Model)
            {
                <tr>
                    <td>@record.CIS</td>
                    <td>@record.BarCode</td>
                    <td>@record.RecordType</td>
                </tr>
            }
        </tbody>
    </table>


}

@if (ViewData["DigitizedBoxes"] is Dictionary<int, List<RecordsMaster.Models.RecordItemModel>> allBoxes && allBoxes.Any())
{
    <h4 class="mt-4">All Boxes</h4>
    <table class="table">
        <thead>
            <tr>
                <th>Box</th>
                <th>Records</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var box in allBoxes)
            {
                var allDigitized = box.Value.All(r => r.Digitized);
                var rowClass = allDigitized ? "table-success" : "table-warning";
                <tr class="@rowClass">
                    <td><strong>@box.Key</strong></td>
                    <td>
                        @foreach (var record in box.Value)
                        {
                            <span class="me-2">@record.BarCode</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
