@model IEnumerable<RecordsMaster.Models.RecordItemModel>

@{
    ViewData["Title"] = "Records";
}

@if (User.IsInRole("Admin"))
{
    var allCheckedOut = ViewBag.AllCheckedOutRecords as IEnumerable<RecordsMaster.Models.RecordItemModel> ?? Enumerable.Empty<RecordsMaster.Models.RecordItemModel>();
    <h5 class="ml-3">@(ViewBag.FilterEmail != null ? $"Records checked out by {ViewBag.FilterEmail}" : "Currently checked out")</h5>
    @if (!allCheckedOut.Any())
    {
        <p>No records are currently checked out.</p>
    }
    else
    {
        <table class="table table-striped border-1">
            <thead class="table-dark"> 
                <tr>
                    <th>Case#</th>
                    <th>BarCode</th>
                    <th>Record Type</th>
                    <th>Checked Out To</th>
                    <th>Delivery Message</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var record in allCheckedOut)
            {
                var activeCheckout = record.CheckoutHistoryRecords
                    .Where(h => h.ReturnedDate == null)
                    .OrderByDescending(h => h.CheckedOutDate)
                    .FirstOrDefault();
                <tr>
                    <td><a asp-area="" asp-controller="RecordCheckout" asp-action="Checkout" asp-route-id="@record.ID" asp-route-cis="@record.CIS">@record.CIS</a></td>
                    <td>@record.BarCode</td>
                    <td>@record.RecordType</td>
                    <td>@(record.CheckedOutTo?.Email ?? "-")</td>
                    <td>@(activeCheckout?.DeliveryMessage ?? "-")</td>
                </tr>
            }
            </tbody>
        </table>
    }
}

else{

    @if (!Model.Any(record => record.Requested || record.CheckedOut))
{
    <p>You have no records requested or checked out.</p>
}
else
{
    if (Model.Any(record => record.Requested))
    {
        <h5>Requested Records</h5>
        <table class="table table-striped border-1">
            <thead class="table-dark"> 
                <tr>
                    <th>Case#</th>
                    <th>BarCode</th>
                    <th>Record Type</th>
                    @if (User.IsInRole("Admin"))
                    {   
                        <th>Location</th>
                        <th>Box Number</th>
                        <th>Digitized</th>
                    }
                    <th>Closing Date</th>
                    <th>Destroy Date</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var record in Model.Where(record => record.Requested))
            {
                <tr>
                    <td><a asp-area="" asp-controller="RecordCheckout" asp-action="Checkout" asp-route-id="@record.ID" asp-route-cis="@record.CIS">@record.CIS</a></td>
                    <td>@record.BarCode</td>
                    <td>@record.RecordType</td>
                    @if (User.IsInRole("Admin")){
                        <td>@record.Location</td>
                        <td>@(record.BoxNumber.HasValue ? record.BoxNumber.ToString() : "-")</td>
                        <td>@(record.Digitized ? "Yes" : "No")</td>
                    }
                    <td>@(record.ClosingDate?.ToString("MM/dd/yyyy") ?? "-")</td>
                    <td>@(record.DestroyDate?.ToString("MM/dd/yyyy") ?? "-")</td>
                </tr>
            }
            </tbody>
        </table>
    }

    if (Model.Any(record => record.CheckedOut))
    {
        <h5>Checked Out Records</h5>
        <table class="table table-striped border-1">
            <thead class="table-dark"> 
                <tr>
                    <th>Case#</th>
                    <th>BarCode</th>
                    <th>Record Type</th>
                    @if (User.IsInRole("Admin"))
                    {
                        <th>Location</th>
                        <th>Box Number</th>
                        <th>Digitized</th>
                    }
                    <th>Closing Date</th>
                    <th>Destroy Date</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var record in Model.Where(record => record.CheckedOut))
            {
                <tr>
                    <td><a asp-area="" asp-controller="RecordCheckout" asp-action="Checkout" asp-route-id="@record.ID" asp-route-cis="@record.CIS">@record.CIS</a></td>
                    <td>@record.BarCode</td>
                    <td>@record.RecordType</td>
                    @if (User.IsInRole("Admin"))
                    {
                        <td>@record.Location</td>
                        <td>@(record.BoxNumber.HasValue ? record.BoxNumber.ToString() : "-")</td>
                        <td>@(record.Digitized ? "Yes" : "No")</td>
                    }
                    <td>@(record.ClosingDate?.ToString("MM/dd/yyyy") ?? "-")</td>
                    <td>@(record.DestroyDate?.ToString("MM/dd/yyyy") ?? "-")</td>
                </tr>
            }
            </tbody>
        </table>
    }
}
}

